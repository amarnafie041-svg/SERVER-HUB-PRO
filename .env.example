# Server Hub v5 - Environment Configuration

# REQUIRED: Secret key for JWT token signing
SESSION_SECRET=your-super-secret-key-change-this

# REQUIRED if using AI: NVIDIA API Key (get from build.nvidia.com)
NVIDIA_API_KEY=

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=production

# Files base directory
FILES_BASE_DIR=/home/runner

# CORS origin (comma-separated for multiple origins)
CORS_ORIGIN=https://your-domain.onrender.com,http://localhost:5180

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Cloudflare Configuration ─────────────────────────────────────────
# Set to your Cloudflare domain (e.g. https://server-hub.yourdomain.com)
CLOUDFLARE_DOMAIN=

# Enable Cloudflare proxy (true/false)
CLOUDFLARE_ENABLED=true

# Cloudflare API Token for DNS management (optional)
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID (optional, from Cloudflare dashboard)
CLOUDFLARE_ZONE_ID=

# Cloudflare Turnstile (CAPTCHA) keys (optional, recommended)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
