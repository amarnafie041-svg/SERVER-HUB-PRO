FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/runner
ENV SHELL=/bin/bash
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    wget \
    git \
    nano \
    vim \
    htop \
    zip \
    unzip \
    tar \
    gzip \
    ca-certificates \
    openssh-client \
    iproute2 \
    dnsutils \
    netcat-openbsd \
    python3 \
    python3-pip \
    python3-venv \
    nodejs \
    npm \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python

RUN npm install -g yarn pnpm 2>/dev/null || true

RUN groupadd -g 1000 runner && \
    useradd -m -u 1000 -g runner -d /home/runner -s /bin/bash runner && \
    mkdir -p /home/runner/projects /home/runner/tmp && \
    chown -R runner:runner /home/runner

RUN echo "runner ALL=(ALL) NOPASSWD: /usr/bin/apt, /usr/bin/apt-get, /usr/bin/pip*, /usr/bin/npm*, /usr/bin/node*" > /etc/sudoers.d/runner

USER runner
WORKDIR /home/runner

RUN python3 -m venv /home/runner/.venv 2>/dev/null || true

CMD ["/bin/bash", "--login"]
